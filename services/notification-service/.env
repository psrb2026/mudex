# Notification Service - Mudex Corrigido
NODE_ENV=development
PORT=3007
SERVICE_NAME=notification-service

# Banco de Dados (Apontando para o container real)
DB_HOST=mudex-postgres
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
DB_DIALECT=postgres

# Redis Corrigido (Usando o nome da rede Docker)
REDIS_URL=redis://mudex-redis:6379

# RabbitMQ Corrigido (Fundamental para receber alertas de corridas)
RABBITMQ_URL=amqp://admin:admin@mudex-rabbitmq:5672

# JWT PADRONIZADO (Para validar as notificações enviadas)
JWT_SECRET=mudex_super_secret

# Firebase (fake para desenvolvimento)
FIREBASE_PROJECT_ID=mudex-dev
FIREBASE_CLIENT_EMAIL=firebase@fake.com
FIREBASE_PRIVATE_KEY="fake-key"
