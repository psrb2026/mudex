# Ride Service - Mudex Corrigido
NODE_ENV=development
PORT=3003
SERVICE_NAME=ride-service

# Banco de Dados (Apontando para o container correto)
DB_HOST=mudex-postgres
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
DB_DIALECT=postgres

# Redis e RabbitMQ (Usando os nomes reais dos containers)
REDIS_URL=redis://mudex-redis:6379
RABBITMQ_URL=amqp://admin:admin@mudex-rabbitmq:5672

# JWT - PADRONIZADO (Deve ser igual ao Gateway e Auth)
JWT_SECRET=mudex_super_secret

# Outros serviços (Corrigidos para a rede do Docker no Codespaces)
USER_SERVICE_URL=http://mudex-user-service:3002
DISPATCH_SERVICE_URL=http://mudex-dispatch-service:3004
PAYMENT_SERVICE_URL=http://mudex-payment-service:3006
NOTIFICATION_SERVICE_URL=http://mudex-notification-service:3007
