# User Service - Mudex Corrigido
NODE_ENV=development
PORT=3002
SERVICE_NAME=user-service

# Banco de Dados (Mantendo a conexão interna do Docker)
DB_HOST=postgres
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
DB_DIALECT=postgres

# Redis e RabbitMQ (Usando os nomes da rede do Docker)
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# JWT - PADRONIZADO PARA ACABAR COM O ERRO 401
JWT_SECRET=mudex_super_secret

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
