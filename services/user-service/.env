# User Service - Mudex
NODE_ENV=development
PORT=3002
SERVICE_NAME=user-service

# PostgreSQL (Docker)
DB_HOST=postgres
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
DB_DIALECT=postgres

# Redis (Docker)
REDIS_URL=redis://redis:6379

# RabbitMQ (Docker)
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# JWT
JWT_SECRET=mudex-super-secret-key-change-this-in-production-32chars-long

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
