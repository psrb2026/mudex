# Payment Service - Mudex Corrigido
NODE_ENV=development
PORT=3006
SERVICE_NAME=payment-service

# Banco de Dados (Apontando para o container real na rede do Docker)
DB_HOST=mudex-postgres
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
DB_DIALECT=postgres

# Redis Corrigido (Usando o nome do container no Codespaces)
REDIS_URL=redis://mudex-redis:6379

# JWT PADRONIZADO (Para o Gateway autorizar pagamentos)
JWT_SECRET=mudex_super_secret

# Stripe (modo teste)
STRIPE_SECRET_KEY=sk_test_fake
STRIPE_PUBLISHABLE_KEY=pk_test_fake
STRIPE_WEBHOOK_SECRET=whsec_fake
