# ============================================
# MUDEX - CONFIGURAÇÃO GLOBAL
# ============================================

# Ambiente
NODE_ENV=development

# Segurança (32+ caracteres)
JWT_SECRET=mudex-super-secret-key-change-this-in-production-32chars-long
JWT_REFRESH_SECRET=mudex-refresh-secret-key-also-change-this-32chars-min

# PostgreSQL (Docker local) - SENHA: jesus2018
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=
DB_NAME_PREFIX=mudex

# Redis (Docker local)
REDIS_URL=redis://localhost:6379

# RabbitMQ (Docker local)
RABBITMQ_URL=amqp://admin:admin@localhost:5672
RABBITMQ_MANAGEMENT=http://localhost:15672

# Stripe (modo teste)
STRIPE_SECRET_KEY=sk_test_fake
STRIPE_PUBLISHABLE_KEY=pk_test_fake
STRIPE_WEBHOOK_SECRET=whsec_fake

# Firebase (fake para desenvolvimento)
FIREBASE_PROJECT_ID=mudex-dev
FIREBASE_CLIENT_EMAIL=firebase@fake.com
FIREBASE_PRIVATE_KEY="fake-key"

# Google Maps (obtenha em console.cloud.google.com)
GOOGLE_MAPS_API_KEY=AIzaFakeKey

# ML Serving
ML_SERVING_URL=http://localhost:8000

# Ports dos serviços
GATEWAY_PORT=3000
AUTH_PORT=3001
USER_PORT=3002
RIDE_PORT=3003
DISPATCH_PORT=3004
LOCATION_PORT=3005
PAYMENT_PORT=3006
NOTIFICATION_PORT=3007
ANALYTICS_PORT=3008