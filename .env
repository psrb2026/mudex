# Banco de Dados (Postgres Docker)
# Nota: Usamos o nome do serviço definido no docker-compose
POSTGRES_USER=mudex
POSTGRES_PASSWORD=mudex123
POSTGRES_DB=mudex_db
DB_HOST=mudex-postgres
DB_PORT=5432

# Cache (Redis Docker)
# Trocamos 127.0.0.1 pelo nome do serviço redis
REDIS_URL=redis://mudex-redis:6379

# Mensageria (RabbitMQ Docker)
# Trocamos 127.0.0.1 pelo nome do serviço rabbitmq
RABBITMQ_URL=amqp://guest:guest@mudex-rabbitmq:5672

# Analytics Specific
DB_NAME_ANALYTICS=mudex_analytics
PORT_ANALYTICS=3008
