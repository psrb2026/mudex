# Configuração Corrigida para bater com o Docker Compose
NODE_ENV=development
PORT=3000

# Banco de Dados e Redis (Usando os nomes que o Docker conhece)
DB_HOST=postgres
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
DB_DIALECT=postgres

REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# A CHAVE DEVE SER IGUAL À DO DOCKER-COMPOSE
JWT_SECRET=mudex_super_secret
JWT_REFRESH_SECRET=mudex_super_secret_refresh

# URLs DOS SERVIÇOS (Usando os nomes curtos/aliases do Compose)
AUTH_SERVICE_URL=http://auth-service:3001
LOCATION_SERVICE_URL=http://location-service:3005
USER_SERVICE_URL=http://user-service:3002
RIDE_SERVICE_URL=http://ride-service:3003
DISPATCH_SERVICE_URL=http://dispatch-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3006
NOTIFICATION_SERVICE_URL=http://notification-service:3007
ANALYTICS_SERVICE_URL=http://analytics-service:3008
