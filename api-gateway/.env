# API Gateway - Mudex
NODE_ENV=development
PORT=3000

# PostgreSQL (Docker)
# Se o seu banco no docker-compose se chamar 'db' ou 'postgres', use esse nome:
DB_HOST=mudex-db
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
DB_DIALECT=postgres

# Redis (Docker)
REDIS_URL=redis://mudex-redis:6379

# RabbitMQ (Docker)
RABBITMQ_URL=amqp://admin:admin@mudex-rabbitmq:5672

# JWT
JWT_SECRET=mudex-super-secret-key-change-this-in-production-32chars-long
JWT_REFRESH_SECRET=mudex-refresh-secret-key-also-change-this-32chars-min

# Servicos (Ajustados para os nomes dos containers Docker)
AUTH_SERVICE_URL=http://mudex-auth-service:3001
USER_SERVICE_URL=http://mudex-user-service:3002
RIDE_SERVICE_URL=http://mudex-ride-service:3003
DISPATCH_SERVICE_URL=http://mudex-dispatch-service:3004
LOCATION_SERVICE_URL=http://mudex-location-service:3005
PAYMENT_SERVICE_URL=http://mudex-payment-service:3006
NOTIFICATION_SERVICE_URL=http://mudex-notification-service:3007
ANALYTICS_SERVICE_URL=http://mudex-analytics-service:3008
