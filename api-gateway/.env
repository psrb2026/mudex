# API Gateway - Mudex
NODE_ENV=development
PORT=3000

# PostgreSQL (Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=mudex
DB_PASSWORD=mudex123
DB_NAME=mudex_db
